    "ACTION_FROM_USER" : {
      "comment" : "APNs loc-key (Sygnal) for a /me action outside a named room. loc-args: [from_display, action_display]",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ %2$@"
          }
        }
      }
    },
    "ACTION_FROM_USER_IN_ROOM" : {
      "comment" : "APNs loc-key (Sygnal) for a /me action in a named room. loc-args: [room_display, from_display, action_display]",
